APP_NAME="SchoolMS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Kolkata
APP_URL=https://skoolms.msitsols.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ---------------------------------------------------------------------------
# Master database (holds tenants + global user accounts)
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=PREFIX_skoolms_master
DB_USERNAME=PREFIX_app
DB_PASSWORD=YOUR_DB_PASSWORD

# ---------------------------------------------------------------------------
# Tenant template connection
# ---------------------------------------------------------------------------
TENANT_DB_CONNECTION=mysql
TENANT_DB_HOST=localhost
TENANT_DB_PORT=3306
TENANT_DB_DATABASE=PREFIX_skoolms_tenant_template
TENANT_DB_USERNAME=PREFIX_app
TENANT_DB_PASSWORD=YOUR_DB_PASSWORD

DB_ROOT_USERNAME=PREFIX_app
DB_ROOT_PASSWORD=YOUR_DB_PASSWORD

# Domain used to build tenant URLs (e.g. lba.msitsols.com)
TENANT_DOMAIN_BASE=msitsols.com
APP_DOMAIN=msitsols.com
MASTER_SUBDOMAIN=skoolms

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.msitsols.com
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@msitsols.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
